# =============================================================================
# PSKloud Prospector - Secrets Template
# =============================================================================
# Copia este archivo como secrets.toml y completa los valores.
# En Streamlit Cloud, configura estas mismas claves en:
#   https://share.streamlit.io → Settings → Secrets
#
# ⚠️ NUNCA subas secrets.toml al repositorio (está en .gitignore)
# =============================================================================

# API Key de Hunter.io (opcional - también se puede ingresar manualmente)
HUNTER_API_KEY = "tu-api-key-aqui"

# SMTP por defecto (opcional - se puede configurar manualmente en la app)
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = 587
SMTP_EMAIL = "tu-email@gmail.com"
SMTP_PASSWORD = "tu-contrasena-de-aplicacion"
